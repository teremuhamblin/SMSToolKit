{
  "name": "smstoolkit",
  "version": "1.0.0",
  "description": "SMSToolKit — CyberTech SMS Analyzer, Tools & Config Engine",
  "author": "Teremu",
  "license": "MIT",

  "type": "module",

  "scripts": {
    "dev": "live-server ./ --port=3000 --open=index.html",
    "format": "prettier --write .",
    "lint": "eslint .",
    "check": "npm run format && npm run lint",
    "build": "echo '⚡ Build statique terminé — aucun bundler requis.'",
    "prepare": "npm run format"
  },

  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.2.0",
    "live-server": "^1.2.2"
  },

  "prettier": {
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "printWidth": 100,
    "trailingComma": "none",
    "bracketSpacing": true
  },

  "eslintConfig": {
    "env": {
      "browser": true,
      "es2022": true
    },
    "extends": ["eslint:recommended", "prettier"],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {
      "no-unused-vars": "warn",
      "no-console": "off",
      "import/no-unresolved": "off"
    }
  }
}
